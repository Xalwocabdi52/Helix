# ─────────────────────────────────────────────────────────────────────────────
# Helix — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Project root (absolute path to where you cloned Helix)
PROJECT_ROOT=/Users/yourname/Developer/Helix

# Claude binary path (find with: which claude)
CLAUDE_BIN=/Users/yourname/.local/bin/claude

# Node binary (find with: which node)
NODE_BIN=/Users/yourname/.nvm/versions/node/v20.0.0/bin/node

# ─── Voice Services ─────────────────────────────────────────────────────────
# Whisper (STT) — local server, typically on :2022
WHISPER_PORT=2022

# Kokoro (TTS) — local server, typically on :8880
KOKORO_PORT=8880

# Voice sample rate (match your Whisper server config)
VOICEMODE_SAMPLE_RATE=32000

# ─── Telegram ────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram user ID (get from @userinfobot)
TELEGRAM_ALLOWED_USER_IDS=123456789

# ─── Memory ──────────────────────────────────────────────────────────────────
# Where memory JSON files live (relative to PROJECT_ROOT)
MEMORY_DIR=memory

# ─── Example Loop (content-loop) ────────────────────────────────────────────
# Only needed if running the example/content-loop

# Reddit credentials
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# Gumroad (optional — for revenue tracking)
GUMROAD_ACCESS_TOKEN=your_gumroad_token

# Beehiiv newsletter (optional)
BEEHIIV_API_KEY=your_beehiiv_key
BEEHIIV_PUB_ID=your_publication_id

# Business URLs (customize for your loop)
BUSINESS_URL=https://yourbusiness.com
GUMROAD_PRODUCT_URL=https://yourstore.gumroad.com/l/your-product
NEWSLETTER_URL=https://yournewsletter.beehiiv.com/subscribe

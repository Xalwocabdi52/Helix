{
  "mcpServers": {
    "helix-mac": {
      "command": "NODE_BIN",
      "args": ["PROJECT_ROOT/mcp-servers/helix-mac/dist/index.js"],
      "env": {
        "PROJECT_ROOT": "PROJECT_ROOT"
      }
    },
    "helix-memory": {
      "command": "NODE_BIN",
      "args": ["PROJECT_ROOT/mcp-servers/helix-memory/dist/index.js"],
      "env": {
        "MEMORY_DIR": "PROJECT_ROOT/memory",
        "PROJECT_ROOT": "PROJECT_ROOT"
      }
    },
    "helix-agents": {
      "command": "NODE_BIN",
      "args": ["PROJECT_ROOT/mcp-servers/helix-agents/dist/index.js"],
      "env": {
        "PROJECT_ROOT": "PROJECT_ROOT",
        "CLAUDE_BIN": "CLAUDE_BIN"
      }
    },
    "helix-telegram": {
      "command": "NODE_BIN",
      "args": ["PROJECT_ROOT/mcp-servers/helix-telegram/dist/index.js"],
      "env": {
        "PROJECT_ROOT": "PROJECT_ROOT",
        "CLAUDE_BIN": "CLAUDE_BIN"
      }
    }
  }
}
